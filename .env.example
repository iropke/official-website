DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# -- reCAPTCHA v3 (Project Inquiry form)
# Register at https://www.google.com/recaptcha/admin
# Both keys are also required in Vercel UI (Production / Preview / Development)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -- Resend (Project Inquiry confirmation + admin notification emails)
# Issue at https://resend.com/api-keys. Sending domain (e.g. iropke.com) must be
# verified in the Resend console before delivery.
# Required in Vercel UI (Production / Preview / Development).
RESEND_API_KEY=
# From address — must use a verified domain. Defaults to "Iropke <hello@iropke.com>".
INQUIRY_FROM_EMAIL=
# Admin notification recipient. Defaults to "hello@iropke.com".
INQUIRY_TO_EMAIL=
